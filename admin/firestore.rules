rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tournaments
    // Fields: name, date, buyIn, status, maxPlayers, currentPlayers, prizePool, description, createdAt
    //
    // Collection: players
    // Fields: name, email, phone, totalWinnings, tournamentsPlayed
    //
    // Collection: tournaments/{tournamentId}/registrations
    // Fields: tournamentId, playerId, playerName, status, rank, winnings, registeredAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "langsb16@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidTournament(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.buyIn is number && data.buyIn >= 0 &&
             data.status in ['upcoming', 'active', 'completed', 'cancelled'];
    }

    function isValidPlayer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    function isValidRegistration(data) {
      return data.tournamentId is string && data.playerId is string &&
             data.status in ['registered', 'paid', 'checked-in', 'eliminated'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidTournament(request.resource.data);
      
      match /registrations/{registrationId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin() && isValidRegistration(request.resource.data);
      }
    }

    match /players/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidPlayer(request.resource.data);
    }
  }
}
